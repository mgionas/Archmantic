{
  "name": "archmantic",
  "version": "1.16.0",
  "description": "Archmantic — an always-on Solution Architect: a living, grounded architecture model + diagrams for humans and AI agents (via MCP). Detects TS/JS and PHP/Laravel stacks, monorepos, API surface, and data models.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/mgionas/Archmantic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgionas/Archmantic.git"
  },
  "bugs": {
    "url": "https://github.com/mgionas/Archmantic/issues"
  },
  "keywords": [
    "architecture",
    "diagrams",
    "mcp",
    "ai-agents",
    "bpmn",
    "c4",
    "reverse-engineering",
    "documentation",
    "static-analysis",
    "monorepo",
    "laravel",
    "php",
    "nestjs",
    "vue",
    "inertia",
    "erd"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "archmantic": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node --test \"test/**/*.test.mjs\"",
    "test:ci": "npm run build && node --test \"test/**/*.test.mjs\"",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2"
  },
  "optionalDependencies": {
    "mysql2": "^3.11.0",
    "pg": "^8.13.0"
  }
}
