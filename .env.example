# Copy to .env.local (gitignored) and fill in real values. NEVER put real
# secrets in this file — it is committed to git.

# Neon Postgres — the platform/cloud store. Used by `push`/`pull` (direct mode)
# and the web app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Clerk (web platform auth). From your Clerk application dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Archmantic managed-SaaS push (optional). When ARCHMANTIC_TOKEN is set,
# `archmantic push` uploads via the deployed API (org-scoped) instead of writing
# the DB directly. Generate the token in the web app's Settings page.
ARCHMANTIC_TOKEN=arch_xxx
ARCHMANTIC_API_URL=https://your-app.vercel.app
